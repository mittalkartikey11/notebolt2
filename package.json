{
  "name": "nexus-copilot",
  "version": "1.0.0",
  "description": "Production-grade desktop AI copilot for meetings, coding practice, and live contextual assistance",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "dev:renderer": "vite",
    "build": "tsc && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dist": "npm run build && npm run build:electron && electron-builder",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "keywords": [
    "electron",
    "ai",
    "copilot",
    "meeting-assistant",
    "coding-interview",
    "supabase",
    "rag"
  ],
  "author": "Nexus Copilot Team",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@supabase/supabase-js": "^2.45.0",
    "anthropic": "^0.32.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "groq-sdk": "^0.9.0",
    "lucide-react": "^1.14.0",
    "openai": "^4.73.0",
    "pdf-parse": "^1.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.15.0",
    "shiki": "^1.24.0",
    "uuid": "^11.0.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.nexus.copilot",
    "productName": "Nexus Copilot",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
